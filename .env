# Comma-separated list of allowed origins (update to your domain in production)
CORS_ALLOWED_ORIGINS=http://cnu-nu.com,http://cnu-nu.com:3000, http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
